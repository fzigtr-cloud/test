            if (!name) return;

            if (!('showDirectoryPicker' in window)) {
                const confirmFallback = confirm('متصفحك لا يدعم إدارة الملفات المتقدمة.\nهل تريد حفظ المشروع في التخزين المحلي؟');
                if (!confirmFallback) return;
