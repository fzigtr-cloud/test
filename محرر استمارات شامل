        function changePaperSize() {
            const sel = document.getElementById('paperSize');
            const customW = document.getElementById('customWidth');
            const customH = document.getElementById('customHeight');
            if (sel.value === 'Custom') { customW.disabled = false;
                customH.disabled = false; } else { customW.disabled = true;
                customH.disabled = true; const size = paperSizes[sel.value];
                customW.value = size.w;
                customH.value = size.h; }
            applyPaperSize();
            savePositionsSilent();
        }

        function applyPaperSize() {
            const sel = document.getElementById('paperSize');
            let w, h;
            if (sel.value === 'Custom') { w = parseInt(document.getElementById('customWidth').value) || 210;
                h = parseInt(document.getElementById('customHeight').value) || 297; } else { const size = paperSizes[sel
                    .value];
                w = size.w;
                h = size.h; }
            const container = document.getElementById('canvasContainer');
            const wrapper = document.getElementById('canvasWrapper');
            const maxW = wrapper.clientWidth - 20;
            const maxH = wrapper.clientHeight - 20;
            const scaleX = maxW / w;
            const scaleY = maxH / h;
            const scale = Math.min(scaleX, scaleY, 3);
            const displayW = w * scale;
            const displayH = h * scale;
            container.style.width = displayW + 'px';
            container.style.height = displayH + 'px';
            const img = document.getElementById('formImage');
            img.style.width = '100%';
            img.style.height = '100%';
            img.style.objectFit = 'contain';
            if (gridVisible) drawGrid();
            setTimeout(drawRulers, 50);
        }

