                span.style.fontFamily = 'inherit';
                span.style.fontWeight = 'inherit';
                span.style.fontStyle = 'inherit';
                span.style.textDecoration = 'inherit';
                span.style.lineHeight = 'inherit';
                span.style.letterSpacing = 'inherit';
                span.style.textAlign = 'inherit';
                contentSpan.appendChild(span);
                div.dataset.value = displayText || value || '';
            }

            div.appendChild(contentSpan);

            const handle = document.createElement('div');
            handle.className = 'resize-handle';
            div.appendChild(handle);
            handle.addEventListener('mousedown', (e) => {
                e.stopPropagation();
                startResize(e, id);
            });

            div.addEventListener('mousedown', (e) => {
                if (e.target.classList.contains('resize-handle')) return;
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') return;
                if (e.target.closest('.field-content') && !e.target.closest('.drag-handle')) {}
                if (!e.shiftKey && !selectedIds.has(id)) {}
            });

            div.addEventListener('click', (e) => {
                if (e.target.classList.contains('resize-handle')) return;
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') return;
                if (e.target.classList.contains('drag-handle')) return;
                if (e.shiftKey) {
                    toggleSelection(id);
                } else {
                    selectOnly(id);
                }
            });

            dragHandle.addEventListener('mousedown', (e) => {
                e.stopPropagation();
                startDrag(e, id);
            });

            div.addEventListener('dblclick', function(e) {
                e.stopPropagation();
                const type = this.dataset.fieldType;
                selectOnly(id);
                const textInput = document.getElementById('fieldText');
                if (type === 'image') {
                    const fileInput = document.getElementById('imageUpload');
                    if (fileInput) {
                        fileInput.click();
                        fileInput.focus();
                    }
                } else if (type === 'date') {
                    if (textInput && !textInput.disabled) {
                        textInput.focus();
                        textInput.click();
                    }
                } else if (type === 'amount') {
                    if (textInput && !textInput.disabled) {
                        const stored = this.dataset.value || '';
                        textInput.value = stored;
                        textInput.focus();
                        textInput.select();
                    }
                } else {
                    if (textInput && !textInput.disabled) {
                        textInput.focus();
                        textInput.select();
                    }
                }
            });

            container.appendChild(div);
            fields[id] = div;
            return div;
        }

        // ================================================================
        // اختيار متعدد
        // ================================================================

        function selectOnly(id) {
            selectedIds.clear();
            selectedIds.add(id);
            selectedId = id;
            updateSelectionUI();
            updatePropertiesPanel(id);
            highlightSelected();
        }

        function toggleSelection(id) {
            if (selectedIds.has(id)) {
                selectedIds.delete(id);
                if (selectedIds.size === 0) {
                    selectedId = null;
                    document.getElementById('fieldId').value = '';
                } else {
                    const first = selectedIds.values().next().value;
                    selectedId = first;
                    updatePropertiesPanel(first);
                }
            } else {
                selectedIds.add(id);
                selectedId = id;
                updatePropertiesPanel(id);
            }
            updateSelectionUI();
            highlightSelected();
        }

        function selectAll() {
            selectedIds.clear();
            Object.keys(fields).forEach(id => selectedIds.add(id));
            if (selectedIds.size > 0) {
                selectedId = selectedIds.values().next().value;
                updatePropertiesPanel(selectedId);
            }
            updateSelectionUI();
            highlightSelected();
        }

        function deselectAll() {
            selectedIds.clear();
            selectedId = null;
            document.getElementById('fieldId').value = '';
            updateSelectionUI();
            highlightSelected();
            const canvas = document.getElementById('alignmentCanvas');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            }
        }

        function updateSelectionUI() {
            document.querySelectorAll('.draggable-field').forEach(el => {
                const id = el.dataset.fieldId;
                el.classList.toggle('selected', selectedIds.has(id));
                const handle = el.querySelector('.drag-handle');
                if (handle) {
                    handle.style.display = selectedIds.has(id) ? 'flex' : 'none';
                }
            });
            const count = selectedIds.size;
            const idInput = document.getElementById('fieldId');
            if (count === 0) {
                idInput.value = '';
            } else if (count === 1) {
                idInput.value = selectedId || '';
            } else {
                idInput.value = count + ' عناصر محددة';
            }
            const labelInput = document.getElementById('fieldLabel');
            if (count > 1) {
                labelInput.placeholder = count + ' عناصر محددة - التغيير سيؤثر على الكل';
            } else {
                labelInput.placeholder = 'أدخل اسم المكون...';
            }
        }

        function highlightSelected() {
            document.querySelectorAll('.draggable-field').forEach(el => {
                const id = el.dataset.fieldId;
                el.classList.toggle('selected', selectedIds.has(id));
            });
        }

        function getSelectedElements() {
            const result = [];
            selectedIds.forEach(id => {
                if (fields[id]) result.push(fields[id]);
            });
            return result;
        }

        function getSelectedIds() {
            return Array.from(selectedIds);
        }

        // ================================================================
        // السحب والإفلات (مع دعم متعدد)
        // ================================================================

        function startDrag(e, id) {
            if (!designMode) return;
            const el = fields[id];
            if (!el) return;
            if (!selectedIds.has(id)) {
                selectOnly(id);
            }
            const container = document.getElementById('canvasContainer');
            const rect = container.getBoundingClientRect();
            const elRect = el.getBoundingClientRect();

            const selectedEls = getSelectedElements();
            const offsets = {};
            selectedEls.forEach(sel => {
                const sRect = sel.getBoundingClientRect();
                offsets[sel.dataset.fieldId] = {
                    offsetX: (e.clientX - sRect.left) / rect.width * 100,
                    offsetY: (e.clientY - sRect.top) / rect.height * 100
                };
            });

            dragData = {
                ids: selectedEls.map(s => s.dataset.fieldId),
                offsets: offsets,
                startPositions: {}
            };
            selectedEls.forEach(sel => {
                dragData.startPositions[sel.dataset.fieldId] = {
                    left: parseFloat(sel.style.left) || 0,
                    top: parseFloat(sel.style.top) || 0
                };
            });

            document.addEventListener('mousemove', onDrag);
            document.addEventListener('mouseup', endDrag);
            selectedEls.forEach(sel => {
                sel.style.cursor = 'grabbing';
                sel.style.zIndex = 100;
            });
            e.preventDefault();
        }

        function onDrag(e) {
            if (!dragData) return;
            const container = document.getElementById('canvasContainer');
            const rect = container.getBoundingClientRect();
            const gridSize = parseInt(document.getElementById('gridSize').value) || 5;

            const firstId = dragData.ids[0];
            const firstOffset = dragData.offsets[firstId];
            const firstStart = dragData.startPositions[firstId];
            let newLeft = ((e.clientX - rect.left) / rect.width * 100) - firstOffset.offsetX;
            let newTop = ((e.clientY - rect.top) / rect.height * 100) - firstOffset.offsetY;
            const firstEl = fields[firstId];
            if (firstEl) {
                const w = parseFloat(firstEl.style.width) || 10;
                const h = parseFloat(firstEl.style.height) || 3;
                newLeft = Math.max(0, Math.min(newLeft, 100 - w));
                newTop = Math.max(0, Math.min(newTop, 100 - h));
                if (snapEnabled) {
                    newLeft = snapValue(newLeft, gridSize);
                    newTop = snapValue(newTop, gridSize);
                }
            }

            const dx = newLeft - firstStart.left;
            const dy = newTop - firstStart.top;

            dragData.ids.forEach(id => {
                const el = fields[id];
                if (!el) return;
                const start = dragData.startPositions[id];
                let l = Math.max(0, Math.min(100 - parseFloat(el.style.width), start.left + dx));
                let t = Math.max(0, Math.min(100 - parseFloat(el.style.height), start.top + dy));
                if (snapEnabled) {
                    l = snapValue(l, gridSize);
                    t = snapValue(t, gridSize);
                }
                el.style.left = l + '%';
                el.style.top = t + '%';
            });

            drawAlignmentGuides(firstId);
            if (selectedIds.size === 1) {
                updatePropertiesPanel(firstId);
            }
        }

        function endDrag() {
            if (dragData) {
                dragData.ids.forEach(id => {
                    const el = fields[id];
                    if (el) {
                        el.style.cursor = 'grab';
                        el.style.zIndex = 10;
                    }
                });
                savePositionsSilent();
                dragData = null;
            }
            document.removeEventListener('mousemove', onDrag);
            document.removeEventListener('mouseup', endDrag);
            setTimeout(() => {
                if (selectedIds.size > 0) {
                    const firstId = selectedIds.values().next().value;
                    if (firstId) drawAlignmentGuides(firstId);
                } else {
                    const canvas = document.getElementById('alignmentCanvas');
                    if (canvas) {
                        const ctx = canvas.getContext('2d');
                        ctx.clearRect(0, 0, canvas.width, canvas.height);
                    }
                }
            }, 100);
        }

        // ================================================================
        // التحجيم (مع دعم متعدد)
        // ================================================================

        let resizeDataMulti = null;

        function startResize(e, id) {
            if (!designMode) return;
            const el = fields[id];
            if (!el) return;
            if (!selectedIds.has(id)) {
                selectOnly(id);
            }
            const container = document.getElementById('canvasContainer');
            const rect = container.getBoundingClientRect();
            const selectedEls = getSelectedElements();

            resizeDataMulti = {
                ids: selectedEls.map(s => s.dataset.fieldId),
                startX: e.clientX,
                startY: e.clientY,
                startSizes: {}
            };
            selectedEls.forEach(sel => {
                resizeDataMulti.startSizes[sel.dataset.fieldId] = {
                    width: parseFloat(sel.style.width) || 10,
                    height: parseFloat(sel.style.height) || 3,
                    left: parseFloat(sel.style.left) || 0,
                    top: parseFloat(sel.style.top) || 0
                };
            });

            document.addEventListener('mousemove', onResizeMulti);
            document.addEventListener('mouseup', endResizeMulti);
            e.preventDefault();
        }

        function onResizeMulti(e) {
            if (!resizeDataMulti) return;
            const data = resizeDataMulti;
            const container = document.getElementById('canvasContainer');
            const rect = container.getBoundingClientRect();
            const dx = (e.clientX - data.startX) / rect.width * 100;
            const dy = (e.clientY - data.startY) / rect.height * 100;
            const gridSize = parseInt(document.getElementById('gridSize').value) || 5;

            data.ids.forEach(id => {
                const el = fields[id];
                if (!el) return;
                const start = data.startSizes[id];
                let newW = Math.max(0.5, start.width + dx);
                let newH = Math.max(0.5, start.height + dy);
                if (snapEnabled) {
                    newW = snapValue(newW, gridSize);
                    newH = snapValue(newH, gridSize);
                    newW = Math.max(0.5, newW);
                    newH = Math.max(0.5, newH);
                }
                el.style.width = Math.min(100, newW) + '%';
                el.style.height = Math.min(100, newH) + '%';
            });

            if (selectedIds.size === 1) {
                const firstId = data.ids[0];
                updatePropertiesPanel(firstId);
            }
        }

        function endResizeMulti() {
            if (resizeDataMulti) {
                savePositionsSilent();
                resizeDataMulti = null;
            }
            document.removeEventListener('mousemove', onResizeMulti);
            document.removeEventListener('mouseup', endResizeMulti);
        }

        // ================================================================
        // اختصارات لوحة المفاتيح
        // ================================================================

        document.addEventListener('keydown', function(e) {
            if (selectedIds.size === 0) return;
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.tagName === 'TEXTAREA')
                return;

            const isCtrl = e.ctrlKey || e.metaKey;
            const isShift = e.shiftKey;
            const step = isCtrl ? 0.1 : (isShift ? 0.5 : 0.5);
            let dx = 0,
                dy = 0;

            if (isCtrl && !isShift) {
                switch (e.key) {
                    case 'ArrowUp':
                        dy = -step;
                        break;
                    case 'ArrowDown':
                        dy = step;
                        break;
                    case 'ArrowRight':
                        dx = step;
                        break;
                    case 'ArrowLeft':
                        dx = -step;
                        break;
                    default:
                        return;
                }
                e.preventDefault();
                const ids = getSelectedIds();
                ids.forEach(id => {
                    const el = fields[id];
                    if (!el) return;
                    let newLeft = parseFloat(el.style.left) + dx;
                    let newTop = parseFloat(el.style.top) + dy;
                    const w = parseFloat(el.style.width) || 10;
                    const h = parseFloat(el.style.height) || 3;
                    newLeft = Math.max(0, Math.min(100 - w, newLeft));
                    newTop = Math.max(0, Math.min(100 - h, newTop));
                    el.style.left = newLeft + '%';
                    el.style.top = newTop + '%';
                });
                if (selectedIds.size === 1) {
                    const firstId = ids[0];
                    updatePropertiesPanel(firstId);
                }
                savePositionsSilent();
                return;
            }

            if (isShift && !isCtrl) {
                switch (e.key) {
                    case 'ArrowUp':
                        dy = -step;
                        break;
                    case 'ArrowDown':
                        dy = step;
                        break;
                    case 'ArrowRight':
                        dx = step;
                        break;
                    case 'ArrowLeft':
                        dx = -step;
                        break;
                    default:
                        return;
                }
                e.preventDefault();
                const ids = getSelectedIds();
                ids.forEach(id => {
                    const el = fields[id];
                    if (!el) return;
                    let newW = parseFloat(el.style.width) + dx;
                    let newH = parseFloat(el.style.height) + dy;
                    newW = Math.max(0.5, Math.min(100, newW));
                    newH = Math.max(0.5, Math.min(100, newH));
                    el.style.width = newW + '%';
                    el.style.height = newH + '%';
                });
                if (selectedIds.size === 1) {
                    const firstId = ids[0];
                    updatePropertiesPanel(firstId);
                }
                savePositionsSilent();
                return;
            }

            if (isCtrl && e.key === 'a') {
                e.preventDefault();
                selectAll();
                return;
            }

            if (e.key === 'Escape') {
                deselectAll();
                return;
            }
        });

        // ================================================================
        // لوحة الخصائص
        // ================================================================

        function updatePropertiesPanel(id) {
            if (!id || !fields[id]) {
                if (selectedIds.size === 0) {
                    document.getElementById('fieldId').value = '';
                    document.getElementById('fieldLabel').value = '';
                    document.getElementById('fieldText').value = '';
                }
                return;
            }
            const el = fields[id];
            if (!el) return;
            const type = el.dataset.fieldType;

            document.getElementById('fieldId').value = id;
            const labelTag = el.querySelector('.field-label');
            document.getElementById('fieldLabel').value = labelTag ? labelTag.textContent : '';

            const textInput = document.getElementById('fieldText');

            document.getElementById('fieldX').value = parseFloat(el.style.left) || 0;
            document.getElementById('fieldY').value = parseFloat(el.style.top) || 0;
            document.getElementById('fieldW').value = parseFloat(el.style.width) || 10;
            document.getElementById('fieldH').value = parseFloat(el.style.height) || 3;

            const content = el.querySelector('.field-content');
            if (content) {
                document.getElementById('fieldFontSize').value = parseInt(content.style.fontSize) || 7;
                document.getElementById('fieldFontFamily').value = content.style.fontFamily.split(',')[0].trim() ||
                'Tahoma';
                document.getElementById('fieldColor').value = rgbToHex(content.style.color) || '#000000';
                document.getElementById('fieldBold').checked = content.style.fontWeight === 'bold';
                document.getElementById('fieldItalic').checked = content.style.fontStyle === 'italic';
                document.getElementById('fieldLineHeight').value = parseFloat(content.style.lineHeight) || 1.5;
                document.getElementById('fieldLetterSpacing').value = parseFloat(content.style.letterSpacing) || 0;
                document.getElementById('fieldTextAlign').value = content.style.textAlign || 'right';
                const deco = content.style.textDecoration || 'none';
                document.getElementById('fieldUnderline').checked = deco.includes('underline');
                document.getElementById('fieldTextDecoration').value = deco;
                if (type === 'amount_words') {
                    const vAlign = el.dataset.verticalAlign || 'center';
                    document.getElementById('fieldVerticalAlign').value = vAlign;
                }
                if (type === 'select') {
                    const opts = el.dataset.options || '';
                    document.getElementById('fieldOptions').value = opts;
                }
            }

            const imageUploadGroup = document.getElementById('imageUploadGroup');
            const linkEditGroup = document.getElementById('linkEditGroup');
            const linkInfo = document.getElementById('linkInfo');
            const linkedFieldName = document.getElementById('linkedFieldName');
            const langCurrencyGroup = document.getElementById('langCurrencyGroupProps');
            const dateFormatGroup = document.getElementById('dateFormatGroup');
            const textContentGroup = document.getElementById('textContentGroup');
            const optionsGroup = document.getElementById('optionsGroup');
            const checkboxRadioSettings = document.getElementById('checkboxRadioSettings');

            if (type === 'select') {
                textContentGroup.style.display = 'none';
            } else if (type === 'image') {
                textContentGroup.style.display = 'none';
            } else {
                textContentGroup.style.display = 'block';
            }

            if (type === 'select') {
                optionsGroup.style.display = 'block';
                const opts = el.dataset.options || '';
                document.getElementById('fieldOptions').value = opts;
            } else {
                optionsGroup.style.display = 'none';
            }

            if (type === 'checkbox' || type === 'radio') {
                checkboxRadioSettings.style.display = 'block';
                document.getElementById('showLabelCheck').checked = el.dataset.showLabel === 'true';
                document.getElementById('labelPosition').value = el.dataset.labelPosition || 'right';
                document.getElementById('labelTextAlign').value = el.dataset.labelTextAlign || 'right';
                const size = parseInt(el.dataset.componentSize) || 12;
                document.getElementById('componentSizeSlider').value = size;
                document.getElementById('componentSizeLabel').textContent = size;
                textInput.value = el.dataset.displayText || '';
                setTimeout(() => {
                    updateLabelPosition();
                    updateLabelTextAlign();
                }, 10);
                updateComponentSizeForEl(el);
            } else {
                checkboxRadioSettings.style.display = 'none';
                if (type !== 'select' && type !== 'image') {
                    const contentEl = el.querySelector('.field-content');
                    let displayText = '';
                    if (contentEl) {
                        const span = contentEl.querySelector('span:not(.field-label)');
                        if (span) {
                            displayText = span.textContent.trim();
                        } else {
                            const inputs = contentEl.querySelectorAll('input, select');
                            if (inputs.length > 0) {
                                const input = inputs[0];
                                if (input.tagName === 'INPUT' && input.type === 'text') {
                                    displayText = input.value || '';
                                } else if (input.tagName === 'SELECT') {
                                    displayText = input.options[input.selectedIndex]?.text || '';
                                }
                            }
                        }
                    }
                    textInput.value = displayText;
                } else {
                    textInput.value = '';
                }
            }

            if (type === 'select' || type === 'image') {
                textInput.disabled = true;
                textInput.style.background = 'var(--bg-panel)';
                textInput.style.color = 'var(--text-secondary)';
                textInput.style.cursor = 'not-allowed';
            } else {
                textInput.disabled = false;
                textInput.style.background = '';
                textInput.style.color = '';
                textInput.style.cursor = '';
            }

            if (type === 'date') {
                textInput.type = 'date';
                const stored = el.dataset.value || '';
                if (stored) {
                    const parsed = parseDateInput(stored);
                    if (parsed) textInput.value = parsed;
                } else {
                    textInput.value = '';
                }
            } else {
                textInput.type = 'text';
            }

            const verticalAlignGroup = document.getElementById('verticalAlignGroup');
            if (type === 'amount_words') {
                verticalAlignGroup.style.display = 'block';
            } else {
                verticalAlignGroup.style.display = 'none';
            }

            if (type === 'image') {
                imageUploadGroup.style.display = 'block';
            } else {
                imageUploadGroup.style.display = 'none';
            }

            if (type === 'amount_words') {
                langCurrencyGroup.style.display = 'block';
                const lang = el.dataset.lang || 'ar';
                const currency = el.dataset.currency || 'DZD';
                document.getElementById('amountLanguageProps').value = lang;
                document.getElementById('currencyTypeProps').value = currency;
            } else {
                langCurrencyGroup.style.display = 'none';
            }

            if (type === 'date') {
                dateFormatGroup.style.display = 'block';
                const fmt = el.dataset.dateFormat || 'dd/mm/yyyy';
                document.getElementById('dateFormatProps').value = fmt;
            } else {
                dateFormatGroup.style.display = 'none';
            }

            if (type === 'amount_words') {
                let linkedId = null;
                document.querySelectorAll('.draggable-field[data-field-type="amount"]').forEach(amountEl => {
                    const ids = amountEl.dataset.linkedWordsIds ? amountEl.dataset.linkedWordsIds.split(',') : [];
                    if (ids.includes(id)) {
                        linkedId = amountEl.dataset.fieldId;
                    }
                });
                const linkEditSelect = document.getElementById('linkEditSelect');
                linkEditSelect.innerHTML = '<option value="">-- اختر حقل أرقام --</option>';
                document.querySelectorAll('.draggable-field[data-field-type="amount"]').forEach(amountEl => {
                    const aid = amountEl.dataset.fieldId;
                    const alabel = amountEl.querySelector('.field-label');
                    const opt = document.createElement('option');
                    opt.value = aid;
                    opt.textContent = alabel ? alabel.textContent : aid;
                    if (aid === linkedId) opt.selected = true;
                    linkEditSelect.appendChild(opt);
                });
                linkEditGroup.style.display = 'block';
                if (linkedId && fields[linkedId]) {
                    const linkedTag = fields[linkedId].querySelector('.field-label');
                    linkInfo.style.display = 'block';
                    linkedFieldName.textContent = linkedTag ? linkedTag.textContent : linkedId;
                } else {
                    linkInfo.style.display = 'none';
                }
            } else {
                linkEditGroup.style.display = 'none';
                linkInfo.style.display = 'none';
            }

            if (type === 'amount') {
                const stored = el.dataset.value || '';
                textInput.value = stored;
            } else if (type === 'text' || type === 'amount_words') {
                const stored = el.dataset.value || '';
                textInput.value = stored;
            }
        }

        // ================================================================
        // تحديثات الخصائص
        // ================================================================

        function updateSelectedLabel() {
            const val = document.getElementById('fieldLabel').value;
            const ids = getSelectedIds();
            ids.forEach(id => {
                const el = fields[id];
                if (!el) return;
                const labelTag = el.querySelector('.field-label');
                if (labelTag) labelTag.textContent = val || 'حقل';
            });
            savePositionsSilent();
        }

        function updateSelectedField() {
            if (selectedIds.size === 0) return;
            const val = document.getElementById('fieldText').value;
            const ids = getSelectedIds();
            ids.forEach(id => {
                const el = fields[id];
                if (!el) return;
                const type = el.dataset.fieldType;
                if (type === 'image' || type === 'select') return;
                if (type === 'date') {
                    let dateVal = val;
                    if (dateVal) {
                        const parts = dateVal.split('-');
                        if (parts.length === 3) {
                            dateVal = parts[0] + '-' + parts[1] + '-' + parts[2];
                        } else {
                            const parsed = parseDateInput(dateVal);
                            if (parsed) dateVal = parsed;
                            else return;
                        }
                    }
                    el.dataset.value = dateVal || '';
                    const contentSpan = el.querySelector('.field-content');
                    if (contentSpan) {
                        const span = contentSpan.querySelector('span:not(.field-label)');
                        if (span) {
                            const fmt = el.dataset.dateFormat || 'dd/mm/yyyy';
                            span.textContent = formatDateDisplay(dateVal, fmt);
                        }
                    }
                    savePositionsSilent();
                    return;
                }
                if (type === 'checkbox' || type === 'radio') {
                    el.dataset.displayText = val;
                    const contentSpan = el.querySelector('.field-content');
                    if (contentSpan) {
                        const lblSpan = contentSpan.querySelector('span:not(.field-label)');
                        if (lblSpan) {
                            lblSpan.textContent = val || ' ';
                        }
                    }
                    savePositionsSilent();
                    return;
                }
                if (type === 'amount') {
                    if (el.updateAmount) {
                        el.updateAmount(val);
                    }
                    return;
                }
                const contentSpan = el.querySelector('.field-content');
                if (contentSpan) {
                    const span = contentSpan.querySelector('span:not(.field-label)');
                    if (span) {
                        span.textContent = val || ' ';
                    }
                    el.dataset.value = val;
                    savePositionsSilent();
                }
            });
        }

        function updateSelectedOptions() {
            if (selectedIds.size === 0) return;
