        function collectFieldsData() {
            const data = {};
            Object.keys(fields).forEach(id => {
                const el = fields[id];
                const content = el.querySelector('.field-content');
                data[id] = {
                    type: el.dataset.fieldType || 'text',
                    left: el.style.left,
                    top: el.style.top,
                    width: el.style.width,
                    height: el.style.height,
                    zIndex: el.style.zIndex || 10,
                    value: el.dataset.value || '',
                    displayText: el.dataset.displayText || '',
                    fontSize: content ? content.style.fontSize : '7px',
                    fontFamily: content ? content.style.fontFamily : 'Tahoma, Arial, sans-serif',
                    color: content ? content.style.color : '#000',
                    fontWeight: content ? content.style.fontWeight : 'normal',
                    fontStyle: content ? content.style.fontStyle : 'normal',
                    lineHeight: content ? content.style.lineHeight : '1.5',
                    letterSpacing: content ? content.style.letterSpacing : '0px',
                    textAlign: content ? content.style.textAlign : 'right',
                    textDecoration: content ? content.style.textDecoration : 'none',
                    verticalAlign: el.dataset.verticalAlign || 'center',
                    options: el.dataset.options || '',
                    showLabel: el.dataset.showLabel || 'false',
                    labelPosition: el.dataset.labelPosition || 'right',
                    labelTextAlign: el.dataset.labelTextAlign || 'right',
                    componentSize: el.dataset.componentSize || '12'
                };
                const labelTag = el.querySelector('.field-label');
                if (labelTag) data[id].label = labelTag.textContent;
                const sel = el.querySelector('select');
                if (sel) {
                    const opts = [];
                    for (let i = 0; i < sel.options.length; i++) { opts.push(sel.options[i].value); }
                    data[id].options = opts.join(',');
                }
                if (el.dataset.linkedWordsIds) data[id].linkedWordsIds = el.dataset.linkedWordsIds;
                if (el.dataset.lang) data[id].lang = el.dataset.lang;
                if (el.dataset.currency) data[id].currency = el.dataset.currency;
                if (el.dataset.imageSrc) data[id].imageSrc = el.dataset.imageSrc;
                if (el.dataset.dateFormat) data[id].dateFormat = el.dataset.dateFormat;
                const hiddenInput = el.querySelector('.field-content input[type="hidden"]');
                if (hiddenInput) {
                    data[id].amountValue = hiddenInput.value;
                }
                if (el.dataset.fieldType === 'checkbox' || el.dataset.fieldType === 'radio') {
                    data[id].checked = el.dataset.value;
                }
            });
            data._settings = {
                paperSize: document.getElementById('paperSize').value,
                customWidth: document.getElementById('customWidth').value,
                customHeight: document.getElementById('customHeight').value,
                gridSize: document.getElementById('gridSize').value,
                gridColor: document.getElementById('gridColor').value,
                gridOpacity: document.getElementById('gridOpacity').value,
                gridLineWidth: document.getElementById('gridLineWidth').value,
                snapEnabled: snapEnabled,
                gridVisible: gridVisible,
                designMode: designMode,
                theme: currentTheme,
                guideColor: guideColor
            };
            return data;
        }

        function loadFieldsData(data) {
            if (!data) return;
            const container = document.getElementById('fieldsContainer');
            container.innerHTML = '';
            fields = {};
            selectedIds.clear();
            selectedId = null;

            if (data._settings) {
                if (data._settings.paperSize) document.getElementById('paperSize').value = data._settings.paperSize;
                if (data._settings.customWidth) document.getElementById('customWidth').value = data._settings.customWidth;
                if (data._settings.customHeight) document.getElementById('customHeight').value = data._settings
                    .customHeight;
                if (data._settings.gridSize) document.getElementById('gridSize').value = data._settings.gridSize;
                if (data._settings.gridColor) document.getElementById('gridColor').value = data._settings.gridColor;
                if (data._settings.gridOpacity) document.getElementById('gridOpacity').value = data._settings.gridOpacity;
                if (data._settings.gridLineWidth) document.getElementById('gridLineWidth').value = data._settings
                    .gridLineWidth;
                snapEnabled = data._settings.snapEnabled || false;
                gridVisible = data._settings.gridVisible || false;
                if (data._settings.designMode !== undefined) designMode = data._settings.designMode;
                if (data._settings.theme) {
                    currentTheme = data._settings.theme;
                    const html = document.documentElement;
                    const btn = document.getElementById('themeToggleBtn');
                    if (currentTheme === 'light') {
                        html.setAttribute('data-theme', 'light');
                        btn.innerHTML = '<span class="icon">☀️</span> ثيم';
                        btn.classList.add('active');
                    } else {
                        html.setAttribute('data-theme', 'dark');
                        btn.innerHTML = '<span class="icon">🌙</span> ثيم';
                        btn.classList.remove('active');
                    }
                }
                if (data._settings.guideColor) {
                    guideColor = data._settings.guideColor;
                    document.getElementById('guideColorPicker').value = guideColor;
                    document.documentElement.style.setProperty('--guide-color', guideColor);
                }
                updateSnapButton();
                updateGridButton();
                if (!designMode) {
                    document.getElementById('designModeBtn').classList.remove('active');
                    document.getElementById('designStatus').textContent = '⛔ عرض';
                    document.getElementById('designStatus').className = 'status-badge design-off';
                    document.getElementById('canvasWrapper').classList.add('design-off');
                    document.getElementById('formImage').classList.add('design-off');
                } else {
                    document.getElementById('designModeBtn').classList.add('active');
                    document.getElementById('designStatus').textContent = '🟢 تصميم';
                    document.getElementById('designStatus').className = 'status-badge';
                    document.getElementById('canvasWrapper').classList.remove('design-off');
                    document.getElementById('formImage').classList.remove('design-off');
                }
                changePaperSize();
            }

            const entries = Object.entries(data);
            entries.forEach(([id, p]) => {
                if (id === '_settings') return;
                let val = p.value || '';
                let displayText = p.displayText || '';
                if (p.type === 'amount' && p.amountValue !== undefined) {
                    val = p.amountValue;
                } else if (p.type === 'checkbox' || p.type === 'radio') {
                    val = p.checked || 'false';
                    displayText = p.displayText || p.label || '';
                }
                const el = createField(
                    id,
                    p.type || 'text',
                    p.label || 'حقل',
                    displayText,
                    val,
                    parseFloat(p.left) || 10,
                    parseFloat(p.top) || 10,
                    parseFloat(p.width) || 12,
                    parseFloat(p.height) || 2.6,
                    parseInt(p.fontSize) || 7,
                    p.fontFamily ? p.fontFamily.split(',')[0].trim() : 'Tahoma',
                    p.color || '#000',
                    p.fontWeight === 'bold',
                    p.fontStyle === 'italic',
                    parseInt(p.zIndex) || 10,
                    p.options || '',
                    parseFloat(p.lineHeight) || 1.5,
                    parseFloat(p.letterSpacing) || 0,
                    p.textAlign || 'right',
                    p.textDecoration || 'none',
                    null,
                    p.lang || 'ar',
                    p.currency || 'DZD',
                    p.imageSrc || '',
                    p.dateFormat || 'dd/mm/yyyy',
                    p.verticalAlign || 'center',
                    p.showLabel || 'false',
                    p.labelPosition || 'right',
                    p.labelTextAlign || 'right'
                );
                if (p.componentSize) {
                    el.dataset.componentSize = p.componentSize;
                }
                if (p.type === 'amount' && p.amountValue !== undefined) {
                    const raw = parseNumberFromInput(p.amountValue);
                    el.dataset.value = String(raw);
                    const span = el.querySelector('.field-content span:not(.field-label)');
                    if (span) span.textContent = formatNumberWithCommas(raw);
                    const hiddenInput = el.querySelector('.field-content input[type="hidden"]');
                    if (hiddenInput) hiddenInput.value = String(raw);
                } else if (p.type === 'date') {
                    el.dataset.value = p.value || '';
                    const fmt = p.dateFormat || 'dd/mm/yyyy';
                    const span = el.querySelector('.field-content span:not(.field-label)');
                    if (span) span.textContent = formatDateDisplay(p.value || '', fmt);
                } else if (p.type === 'checkbox' || p.type === 'radio') {
                    const cb = el.querySelector('.field-content input[type="checkbox"], .field-content input[type="radio"]');
                    if (cb) cb.checked = p.checked === 'true';
                    el.dataset.value = p.checked || 'false';
                    const show = p.showLabel === 'true';
                    const lblSpan = el.querySelector('.field-content span:not(.field-label)');
                    if (lblSpan) {
                        lblSpan.style.display = show ? '' : 'none';
                        lblSpan.textContent = p.displayText || '';
                    }
                    el.dataset.showLabel = p.showLabel || 'false';
                    el.dataset.labelPosition = p.labelPosition || 'right';
                    el.dataset.labelTextAlign = p.labelTextAlign || 'right';
                    el.dataset.displayText = p.displayText || '';
                    const contentSpan = el.querySelector('.field-content');
                    const inputEl = contentSpan.querySelector('input[type="checkbox"], input[type="radio"]');
                    if (inputEl && lblSpan) {
                        applyLabelPosition(contentSpan, inputEl, lblSpan, el.dataset.labelPosition, el.dataset
                            .labelTextAlign);
                    }
                    if (p.componentSize) {
                        el.dataset.componentSize = p.componentSize;
                        updateComponentSizeForEl(el);
                    }
                } else {
                    const span = el.querySelector('.field-content span:not(.field-label)');
                    if (span) span.textContent = p.displayText || p.value || ' ';
                    el.dataset.value = p.value || '';
                    el.dataset.displayText = p.displayText || '';
                }
                if (p.linkedWordsIds) {
                    el.dataset.linkedWordsIds = p.linkedWordsIds;
                }
                if (p.type === 'image' && p.imageSrc) {
                    const img = el.querySelector('.field-content img');
                    if (img) {
                        img.src = p.imageSrc;
                        el.dataset.imageSrc = p.imageSrc;
                    }
                }
                if (p.type === 'amount_words' && p.verticalAlign) {
                    el.dataset.verticalAlign = p.verticalAlign;
                    const content = el.querySelector('.field-content');
                    if (content) {
                        content.style.justifyContent = p.verticalAlign;
                    }
                }
                if (p.type === 'select' && p.options) {
                    el.dataset.options = p.options;
                }
            });

            document.querySelectorAll('.draggable-field[data-field-type="amount_words"]').forEach(wordsEl => {
                const id = wordsEl.dataset.fieldId;
                document.querySelectorAll('.draggable-field[data-field-type="amount"]').forEach(amountEl => {
                    const ids = amountEl.dataset.linkedWordsIds ? amountEl.dataset.linkedWordsIds.split(',') : [];
                    if (ids.includes(id)) {
                        const hiddenInput = amountEl.querySelector('.field-content input[type="hidden"]');
                        if (hiddenInput) {
                            const wLang = wordsEl.dataset.lang || 'ar';
                            const wCurrency = wordsEl.dataset.currency || 'DZD';
                            updateAmountWordsForField(wordsEl, hiddenInput.value, wLang, wCurrency);
                        }
                    }
                });
            });

            setTimeout(() => {
                updateAllAmountWords();
                updateLinkSelects();
                if (gridVisible) {
                    const canvas = document.getElementById('gridCanvas');
                    canvas.style.display = 'block';
                    drawGrid();
                    updateGridButton();
                }
                updateSnapButton();
                applyPaperSize();
                setTimeout(drawRulers, 50);
            }, 50);

            if (selectedIds.size === 0 && Object.keys(fields).length > 0) {
                const firstId = Object.keys(fields)[0];
                selectOnly(firstId);
            }
        }

