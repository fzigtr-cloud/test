        // ================================================================
        // المسطرة (متراكبة)
        // ================================================================

        function drawRulers() {
            const container = document.getElementById('canvasContainer');
            const rect = container.getBoundingClientRect();
            const w = rect.width;
            const h = rect.height;

            // Horizontal ruler
            const hInner = document.getElementById('rulerHInner');
            hInner.innerHTML = '';
            const step = 20;
            const majorStep = 100;
            for (let x = 0; x <= w; x += step) {
                const tick = document.createElement('div');
                tick.className = 'tick' + (x % majorStep === 0 ? ' major' : '');
                tick.style.left = x + 'px';
                hInner.appendChild(tick);
                if (x % majorStep === 0 && x > 0) {
                    const label = document.createElement('div');
                    label.className = 'tick-label';
                    label.style.left = x + 'px';
                    label.textContent = Math.round((x / w) * 100) + '%';
                    hInner.appendChild(label);
                }
            }

            // Vertical ruler
            const vInner = document.getElementById('rulerVInner');
            vInner.innerHTML = '';
            for (let y = 0; y <= h; y += step) {
                const tick = document.createElement('div');
                tick.className = 'tick' + (y % majorStep === 0 ? ' major' : '');
                tick.style.top = y + 'px';
                vInner.appendChild(tick);
                if (y % majorStep === 0 && y > 0) {
                    const label = document.createElement('div');
                    label.className = 'tick-label';
                    label.style.top = y + 'px';
                    label.textContent = Math.round((y / h) * 100) + '%';
                    vInner.appendChild(label);
                }
            }
        }

