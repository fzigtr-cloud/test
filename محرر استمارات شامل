            let linkedId = null;

            if (type === 'select') {
                const opts = prompt('الخيارات مفصولة بفواصل:', 'خيار1,خيار2,خيار3');
                if (opts === null) return;
                options = opts;
                value = opts.split(',')[0].trim();
            } else if (type === 'checkbox' || type === 'radio') {
                value = 'false';
                displayText = prompt('النص الداخلي (المعروض بجانب العنصر):', label || 'اختيار');
                if (displayText === null) displayText = label || 'اختيار';
            } else if (type === 'date') {
                value = '';
            } else if (type === 'amount') {
                const defaultVal = prompt('القيمة الافتراضية (رقم):', '1000');
                if (defaultVal === null) return;
                value = defaultVal;
                const createWords = confirm('هل تريد إنشاء حقل حروف مرتبط تلقائياً؟');
                if (createWords) {
                    const wordsId = generateId('amount_words');
                    const wordsLabel = label + ' (حروف)';
                    createField(wordsId, 'amount_words', wordsLabel, '', '', 10, 10, 14, 3, 7, 'Tahoma', '#000', false,
                        false,
                        10, '', 1.5, 0, 'right', 'none', null, 'ar', 'DZD');
                    linkedId = wordsId;
                    setTimeout(() => {
                        selectOnly(wordsId);
                    }, 10);
                }
            } else if (type === 'image') {
                value = '';
            } else {
                displayText = prompt('النص الداخلي (المحتوى):', '');
                if (displayText === null) return;
                value = displayText;
            }

            const left = 20 + Math.random() * 30,
                top = 20 + Math.random() * 30;
            const lang = 'ar';
            const currency = 'DZD';

            let linkedAmountId = null;
            if (type === 'amount_words') {
                const linkSelect = document.getElementById('linkAmountField');
                linkedAmountId = linkSelect.value || null;
                if (!linkedAmountId) {
                    const firstOption = linkSelect.querySelector('option:not([value=""])');
                    if (firstOption) {
                        linkedAmountId = firstOption.value;
                        linkSelect.value = linkedAmountId;
                    }
                }
            }

            const el = createField(id, type, label, displayText, value, left, top, 14, 3, 7, 'Tahoma', '#000', false, false, 10,
                options, 1.5, 0, 'right', 'none', linkedId, lang, currency, '', 'dd/mm/yyyy', 'center', 'false', 'right',
                'right');

            if (type === 'amount' && linkedId) {
                el.dataset.linkedWordsIds = linkedId;
                setTimeout(() => {
                    const hiddenInput = el.querySelector('.field-content input[type="hidden"]');
                    if (hiddenInput) {
                        const wLang = fields[linkedId]?.dataset?.lang || lang;
                        const wCurrency = fields[linkedId]?.dataset?.currency || currency;
                        updateAmountWordsForField(fields[linkedId], hiddenInput.value, wLang, wCurrency);
                    }
                }, 50);
            }

            if (type === 'amount_words' && linkedAmountId && fields[linkedAmountId]) {
                const amountEl = fields[linkedAmountId];
                const existing = amountEl.dataset.linkedWordsIds ? amountEl.dataset.linkedWordsIds.split(',') : [];
                if (!existing.includes(id)) {
                    existing.push(id);
                    amountEl.dataset.linkedWordsIds = existing.join(',');
                }
                const hiddenInput = amountEl.querySelector('.field-content input[type="hidden"]');
                if (hiddenInput) {
                    updateAmountWordsForField(el, hiddenInput.value, lang, currency);
                }
            }

            selectOnly(id);
            updateLinkSelects();
            savePositionsSilent();
            alert('✅ تم إضافة الحقل');
        }

        function duplicateField() {
            if (selectedIds.size === 0) return alert('⚠️ اختر حقلاً');
            const origId = getSelectedIds()[0];
            const orig = fields[origId];
            if (!orig) return;
            const type = orig.dataset.fieldType || 'text';
            const id = generateId(type);
            const labelTag = orig.querySelector('.field-label');
            const label = labelTag ? labelTag.textContent + ' (نسخة)' : 'نسخة';
            const displayText = orig.dataset.displayText || '';
            const value = orig.dataset.value || '';
            const left = parseFloat(orig.style.left) + 3,
                top = parseFloat(orig.style.top) + 3;
            const width = parseFloat(orig.style.width),
                height = parseFloat(orig.style.height);
            const zIndex = parseInt(orig.style.zIndex) + 1;
            const content = orig.querySelector('.field-content');
            const fontSize = parseInt(content?.style.fontSize) || 7;
            const fontFamily = content?.style.fontFamily || 'Tahoma';
            const color = content?.style.color || '#000';
            const bold = content?.style.fontWeight === 'bold';
            const italic = content?.style.fontStyle === 'italic';
            const lineHeight = content?.style.lineHeight || 1.5;
            const letterSpacing = parseFloat(content?.style.letterSpacing) || 0;
            const textAlign = content?.style.textAlign || 'right';
            const textDecoration = content?.style.textDecoration || 'none';
            const verticalAlign = orig.dataset.verticalAlign || 'center';
            const showLabel = orig.dataset.showLabel || 'false';
            const labelPosition = orig.dataset.labelPosition || 'right';
            const labelTextAlign = orig.dataset.labelTextAlign || 'right';
            const componentSize = orig.dataset.componentSize || '12';
            let options = orig.dataset.options || '';
            const sel = orig.querySelector('select');
            if (sel) {
                const opts = [];
                for (let i = 0; i < sel.options.length; i++) { opts.push(sel.options[i].value); }
                options = opts.join(',');
            }
            const lang = orig.dataset.lang || 'ar';
            const currency = orig.dataset.currency || 'DZD';
            const imageSrc = orig.dataset.imageSrc || '';
            const dateFormat = orig.dataset.dateFormat || 'dd/mm/yyyy';
            let val = value;
            if (type === 'amount') {
                const hiddenInput = orig.querySelector('.field-content input[type="hidden"]');
                if (hiddenInput) val = hiddenInput.value;
            }

            const el = createField(id, type, label, displayText, val, left, top, width, height, fontSize, fontFamily, color,
                bold,
                italic, zIndex, options, lineHeight, letterSpacing, textAlign, textDecoration, null, lang, currency,
                imageSrc, dateFormat, verticalAlign, showLabel, labelPosition, labelTextAlign);

            el.dataset.componentSize = componentSize;

            if (type === 'amount' && orig.dataset.linkedWordsIds) {
                el.dataset.linkedWordsIds = orig.dataset.linkedWordsIds;
                const linkedIds = orig.dataset.linkedWordsIds.split(',');
                linkedIds.forEach(lid => {
                    if (fields[lid]) {
                        const hiddenInput = el.querySelector('.field-content input[type="hidden"]');
                        if (hiddenInput) {
                            const wLang = fields[lid]?.dataset?.lang || lang;
                            const wCurrency = fields[lid]?.dataset?.currency || currency;
                            updateAmountWordsForField(fields[lid], hiddenInput.value, wLang, wCurrency);
                        }
                    }
                });
            }
            if (type === 'image' && imageSrc) {
                const img = el.querySelector('.field-content img');
                if (img) img.src = imageSrc;
            }
            if (type === 'date') {
                const span = el.querySelector('.field-content span:not(.field-label)');
                if (span) {
                    span.textContent = formatDateDisplay(val, dateFormat);
                }
            }
            if (type === 'checkbox' || type === 'radio') {
                const cb = el.querySelector('.field-content input[type="checkbox"], input[type="radio"]');
                if (cb) cb.checked = val === 'true';
                const lblSpan = el.querySelector('.field-content span:not(.field-label)');
                if (lblSpan) {
                    lblSpan.style.display = showLabel === 'true' ? '' : 'none';
                    lblSpan.textContent = displayText || '';
                }
                el.dataset.showLabel = showLabel;
                el.dataset.labelPosition = labelPosition;
                el.dataset.labelTextAlign = labelTextAlign;
                el.dataset.displayText = displayText || '';
                el.dataset.componentSize = componentSize;
                const contentSpan = el.querySelector('.field-content');
                const inputEl = contentSpan.querySelector('input[type="checkbox"], input[type="radio"]');
                if (inputEl && lblSpan) {
                    applyLabelPosition(contentSpan, inputEl, lblSpan, labelPosition, labelTextAlign);
                }
                updateComponentSizeForEl(el);
            }

            selectOnly(id);
            updateLinkSelects();
            savePositionsSilent();
            alert('✅ تم نسخ الحقل');
        }

        function deleteField() {
            if (selectedIds.size === 0) return alert('⚠️ اختر حقلاً');
            const ids = getSelectedIds();
            let hasLinked = false;
            ids.forEach(id => {
                const el = fields[id];
                if (el && el.dataset.fieldType === 'amount') {
                    const linkedIds = el.dataset.linkedWordsIds ? el.dataset.linkedWordsIds.split(',') : [];
                    if (linkedIds.length > 0) hasLinked = true;
                }
            });
            if (hasLinked) {
                if (!confirm('بعض الحقول المحددة مرتبطة بحقول حروف. هل تريد حذفها جميعاً؟')) return;
            }

            ids.forEach(id => {
                const el = fields[id];
                if (!el) return;
                if (el.dataset.fieldType === 'amount') {
                    const linkedIds = el.dataset.linkedWordsIds ? el.dataset.linkedWordsIds.split(',') : [];
                    linkedIds.forEach(lid => {
                        if (fields[lid]) {
                            fields[lid].remove();
                            delete fields[lid];
                        }
                    });
                }
                if (el.dataset.fieldType === 'amount_words') {
                    document.querySelectorAll('.draggable-field[data-field-type="amount"]').forEach(amountEl => {
                        const ids = amountEl.dataset.linkedWordsIds ? amountEl.dataset.linkedWordsIds.split(
                            ',') : [];
                        const newIds = ids.filter(id => id !== el.dataset.fieldId);
                        if (newIds.length > 0) {
                            amountEl.dataset.linkedWordsIds = newIds.join(',');
                        } else {
                            delete amountEl.dataset.linkedWordsIds;
                        }
                    });
                }
                el.remove();
                delete fields[id];
            });

            selectedIds.clear();
            selectedId = null;
            document.getElementById('fieldId').value = '';
            document.getElementById('fieldLabel').value = '';
            document.getElementById('fieldText').value = '';
            updateLinkSelects();
            savePositionsSilent();
            alert('✅ تم حذف ' + ids.length + ' عنصر');
        }

        function clearAllFields() {
            if (!confirm('مسح جميع الحقول؟')) return;
            document.getElementById('fieldsContainer').innerHTML = '';
            fields = {};
            selectedIds.clear();
            selectedId = null;
            document.getElementById('fieldId').value = '';
            document.getElementById('fieldLabel').value = '';
            document.getElementById('fieldText').value = '';
            localStorage.removeItem('sfp01_fields');
            updateLinkSelects();
            document.getElementById('alignmentCanvas').getContext('2d').clearRect(0, 0, 100, 100);
            alert('✅ تم المسح');
        }

        // ================================================================
        // تحريك بالماوس (pan) – محسّن لمنع التعارض
        // ================================================================

        const workspace = document.getElementById('workspace');
        const canvasWrapper = document.getElementById('canvasWrapper');

        workspace.addEventListener('mousedown', (e) => {
            if (e.target.closest('.draggable-field') || e.target.closest('.sidebar') || e.target.closest(
                    '.ruler-container') || e.target.closest('.toolbar')) {
                return;
            }
            if (e.button !== 0) return;
            if (!e.shiftKey) {
                deselectAll();
            }
            isPanning = true;
            panStartX = e.clientX;
            panStartY = e.clientY;
            panStartPX = panX;
            panStartPY = panY;
            workspace.style.cursor = 'grabbing';
        });

        document.addEventListener('mousemove', (e) => {
            if (!isPanning) return;
            const dx = e.clientX - panStartX;
            const dy = e.clientY - panStartY;
            panX = panStartPX + dx;
            panY = panStartPY + dy;
            applyTransform();
            if (gridVisible) drawGrid();
            setTimeout(drawRulers, 20);
        });

        document.addEventListener('mouseup', () => {
            if (isPanning) {
                isPanning = false;
                workspace.style.cursor = 'grab';
            }
        });

        canvasWrapper.addEventListener('wheel', (e) => {
            e.preventDefault();
            const delta = e.deltaY > 0 ? -5 : 5;
            let newZoom = parseInt(document.getElementById('zoomSlider').value) + delta;
            newZoom = Math.max(20, Math.min(300, newZoom));
            document.getElementById('zoomSlider').value = newZoom;
            document.getElementById('zoomValue').textContent = newZoom;
            zoomLevel = newZoom / 100;
            applyTransform();
            if (gridVisible) drawGrid();
            setTimeout(drawRulers, 20);
        }, { passive: false });

        // ================================================================
        // إعادة تحجيم النافذة
        // ================================================================

        window.addEventListener('resize', () => {
            if (gridVisible) drawGrid();
            applyPaperSize();
            setTimeout(drawRulers, 50);
        });

        // ================================================================
        // التهيئة
        // ================================================================

        window.onload = function() {
            loadTheme();
            document.getElementById('paperSize').value = 'A4';
            changePaperSize();

            const saved = localStorage.getItem('sfp01_fields');
            if (saved) {
                try {
                    const data = JSON.parse(saved);
                    loadFieldsData(data);
                } catch (e) { /* ignore */ }
            }

            document.getElementById('formImage').style.opacity = '0.45';
            workspace.style.cursor = 'grab';

            document.getElementById('linkFieldGroup').style.display = 'none';
            document.getElementById('fieldType').addEventListener('change', function() {
                const linkGroup = document.getElementById('linkFieldGroup');
                if (this.value === 'amount_words') {
                    linkGroup.style.display = 'block';
                    updateLinkSelects();
                } else {
                    linkGroup.style.display = 'none';
                }
            });

            document.getElementById('newProjectBtn').addEventListener('click', newProject);
            document.getElementById('openProjectBtn').addEventListener('click', openProject);
            document.getElementById('saveProjectBtn').addEventListener('click', saveProject);
            document.getElementById('exportProjectBtn').addEventListener('click', exportProject);

            document.getElementById('themeToggleBtn').addEventListener('click', toggleTheme);
            document.getElementById('designModeBtn').addEventListener('click', toggleDesignMode);
            document.getElementById('rulerToggleBtn').addEventListener('click', toggleRuler);

            document.getElementById('rulerToggleBtn').classList.add('active');
            document.getElementById('rulerToggleBtn').innerHTML = '<span class="icon">📏</span> مسطرة ✓';

            const alignBtn = document.getElementById('alignGuidesBtn');
            alignBtn.classList.add('btn-active');
            alignBtn.innerHTML = '📐 أدلة ✓';
            document.getElementById('alignmentCanvas').style.display = 'block';

            document.getElementById('guideColorPicker').value = guideColor;
            document.documentElement.style.setProperty('--guide-color', guideColor);

            document.getElementById('designModeBtn').classList.add('active');
            document.getElementById('designModeBtn').innerHTML = '<span class="icon">🔧</span> تصميم ✓';

            setTimeout(() => {
                drawRulers();
                if (Object.keys(fields).length > 0) {
                    const firstId = Object.keys(fields)[0];
                    selectOnly(firstId);
                }
            }, 100);
        };

        // ربط الدوال للاستخدام من HTML
        window.selectOnly = selectOnly;
        window.toggleSelection = toggleSelection;
        window.selectAll = selectAll;
        window.deselectAll = deselectAll;
        window.updateSelectedLabel = updateSelectedLabel;
        window.updateSelectedField = updateSelectedField;
        window.updateSelectedOptions = updateSelectedOptions;
        window.toggleLabelVisibility = toggleLabelVisibility;
        window.updateLabelPosition = updateLabelPosition;
        window.updateLabelTextAlign = updateLabelTextAlign;
        window.updateComponentSize = updateComponentSize;
        window.updateSelectedPos = updateSelectedPos;
        window.updateSelectedSize = updateSelectedSize;
        window.updateSelectedStyle = updateSelectedStyle;
        window.alignFields = alignFields;
        window.distributeFields = distributeFields;
        window.bringToFront = bringToFront;
        window.sendToBack = sendToBack;
        window.bringForward = bringForward;
        window.sendBackward = sendBackward;
        window.toggleGrid = toggleGrid;
        window.toggleSnap = toggleSnap;
        window.toggleAlignGuides = toggleAlignGuides;
        window.savePositions = savePositions;
        window.loadPositions = loadPositions;
        window.resetPositions = resetPositions;
        window.exportJSON = exportJSON;
        window.exportCSV = exportCSV;
        window.importJSON = importJSON;
        window.addField = addField;
        window.duplicateField = duplicateField;
        window.deleteField = deleteField;
        window.clearAllFields = clearAllFields;
        window.drawGrid = drawGrid;
        window.loadImage = loadImage;
        window.resetImage = resetImage;
        window.changeOpacity = changeOpacity;
        window.changeZoom = changeZoom;
        window.resetZoom = resetZoom;
        window.changePaperSize = changePaperSize;
        window.applyPaperSize = applyPaperSize;
        window.updateAllAmountWords = updateAllAmountWords;
        window.updateLinkSelects = updateLinkSelects;
        window.updateLinkBinding = updateLinkBinding;
        window.uploadImage = uploadImage;
        window.updateSelectedLangCurrency = updateSelectedLangCurrency;
        window.updateSelectedDateFormat = updateSelectedDateFormat;
        window.toggleDesignMode = toggleDesignMode;
        window.toggleTheme = toggleTheme;
        window.toggleRuler = toggleRuler;
        window.newProject = newProject;
        window.openProject = openProject;
        window.saveProject = saveProject;
        window.exportProject = exportProject;
        window.exportPDF = exportPDF;
        window.updateGuideColor = updateGuideColor;
    </script>
</body>
</html>
