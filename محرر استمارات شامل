        // ================================================================
        // أدلة المحاذاة (محسّنة)
        // ================================================================

        function drawAlignmentGuides(movingId) {
            if (!alignGuidesEnabled || !movingId) {
                const canvas = document.getElementById('alignmentCanvas');
                if (canvas) {
                    const ctx = canvas.getContext('2d');
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                }
                return;
            }

            if (animationFrameId) {
                cancelAnimationFrame(animationFrameId);
                animationFrameId = null;
            }

            animationFrameId = requestAnimationFrame(() => {
                const canvas = document.getElementById('alignmentCanvas');
                const container = document.getElementById('canvasContainer');
                const rect = container.getBoundingClientRect();
                const dpr = window.devicePixelRatio || 1;
                canvas.width = rect.width * dpr;
                canvas.height = rect.height * dpr;
                canvas.style.width = rect.width + 'px';
                canvas.style.height = rect.height + 'px';
                const ctx = canvas.getContext('2d');
                ctx.scale(dpr, dpr);
                ctx.clearRect(0, 0, rect.width, rect.height);

                const movingEl = fields[movingId];
                if (!movingEl) return;

                const mRect = movingEl.getBoundingClientRect();
                const mLeft = (mRect.left - rect.left) / rect.width * 100;
                const mTop = (mRect.top - rect.top) / rect.height * 100;
                const mRight = mLeft + (parseFloat(movingEl.style.width) || 0);
                const mBottom = mTop + (parseFloat(movingEl.style.height) || 0);
                const mCenterX = mLeft + (parseFloat(movingEl.style.width) || 0) / 2;
                const mCenterY = mTop + (parseFloat(movingEl.style.height) || 0) / 2;

                const threshold = 0.8;
                const guideColor = document.getElementById('guideColorPicker').value || '#f39c12';
                const guideWidth = 1.5;
                const dashPattern = [4, 4];

                const ids = Object.keys(fields).filter(id => id !== movingId);
                const nearbyIds = ids.filter(id => {
                    const el = fields[id];
                    if (!el) return false;
                    const eRect = el.getBoundingClientRect();
                    const eLeft = (eRect.left - rect.left) / rect.width * 100;
                    const eTop = (eRect.top - rect.top) / rect.height * 100;
                    const eRight = eLeft + (parseFloat(el.style.width) || 0);
                    const eBottom = eTop + (parseFloat(el.style.height) || 0);
                    const distX = Math.min(Math.abs(mLeft - eLeft), Math.abs(mRight - eRight), Math.abs(mCenterX - (eLeft +
                        (parseFloat(el.style.width) || 0) / 2)));
                    const distY = Math.min(Math.abs(mTop - eTop), Math.abs(mBottom - eBottom), Math.abs(mCenterY - (eTop +
                        (parseFloat(el.style.height) || 0) / 2)));
                    return distX < 20 || distY < 20;
                });

                nearbyIds.forEach(id => {
                    const el = fields[id];
                    if (!el) return;
                    const eRect = el.getBoundingClientRect();
                    const eLeft = (eRect.left - rect.left) / rect.width * 100;
                    const eTop = (eRect.top - rect.top) / rect.height * 100;
                    const eRight = eLeft + (parseFloat(el.style.width) || 0);
                    const eBottom = eTop + (parseFloat(el.style.height) || 0);
                    const eCenterX = eLeft + (parseFloat(el.style.width) || 0) / 2;
                    const eCenterY = eTop + (parseFloat(el.style.height) || 0) / 2;

                    const matches = [];

                    if (Math.abs(mLeft - eLeft) < threshold) {
                        matches.push({ x: eLeft, y1: 0, y2: rect.height, label: '⬅️' });
                    }
                    if (Math.abs(mRight - eRight) < threshold) {
                        matches.push({ x: eRight, y1: 0, y2: rect.height, label: '➡️' });
                    }
                    if (Math.abs(mTop - eTop) < threshold) {
                        matches.push({ x: 0, y: eTop, x2: rect.width, y2: eTop, label: '⬆️' });
                    }
                    if (Math.abs(mBottom - eBottom) < threshold) {
                        matches.push({ x: 0, y: eBottom, x2: rect.width, y2: eBottom, label: '⬇️' });
                    }
                    if (Math.abs(mCenterX - eCenterX) < threshold) {
                        matches.push({ x: eCenterX, y1: 0, y2: rect.height, label: '⏺️' });
                    }
                    if (Math.abs(mCenterY - eCenterY) < threshold) {
                        matches.push({ x: 0, y: eCenterY, x2: rect.width, y2: eCenterY, label: '⏺️' });
                    }

                    matches.forEach(match => {
                        ctx.save();
                        ctx.strokeStyle = guideColor;
                        ctx.lineWidth = guideWidth;
                        ctx.setLineDash(dashPattern);
                        if (match.x !== undefined && match.y1 !== undefined) {
                            ctx.beginPath();
                            ctx.moveTo((match.x / 100) * rect.width, match.y1);
                            ctx.lineTo((match.x / 100) * rect.width, match.y2);
                            ctx.stroke();
                            ctx.setLineDash([]);
                            ctx.fillStyle = guideColor;
                            ctx.font = '7px Tahoma';
                            ctx.textAlign = 'center';
                            ctx.fillText(match.label || '|', (match.x / 100) * rect.width, 10);
                        } else if (match.x !== undefined && match.y !== undefined) {
                            ctx.beginPath();
                            ctx.moveTo(match.x, (match.y / 100) * rect.height);
                            ctx.lineTo(match.x2, (match.y2 / 100) * rect.height);
                            ctx.stroke();
                            ctx.setLineDash([]);
                            ctx.fillStyle = guideColor;
                            ctx.font = '7px Tahoma';
                            ctx.textAlign = 'right';
                            ctx.fillText(match.label || '—', rect.width - 5, (match.y / 100) * rect.height - 3);
                        }
                        ctx.restore();
                    });
                });
                animationFrameId = null;
            });
        }

        // ================================================================
