    <script>
        // ================================================================
        // دوال تحويل الأرقام إلى حروف (عربية، فرنسية، إنجليزية)
        // ================================================================

        function convertNumDizaineAr(n) {
            if (n === 0) return '';
            var units = ['', 'واحد', 'اثنان', 'ثلاثة', 'أربعة', 'خمسة',
                'ستة', 'سبعة', 'ثمانية', 'تسعة', 'عشرة',
                'أحد عشر', 'اثنا عشر', 'ثلاثة عشر', 'أربعة عشر', 'خمسة عشر',
                'ستة عشر', 'سبعة عشر', 'ثمانية عشر', 'تسعة عشر'
            ];
            var tens = ['', '', 'عشرون', 'ثلاثون', 'أربعون', 'خمسون',
                'ستون', 'سبعون', 'ثمانون', 'تسعون'
            ];
            if (n < 20) return units[n];
            var d = Math.floor(n / 10);
            var u = n % 10;
            if (u === 0) return tens[d];
            return units[u] + ' و' + tens[d];
        }

        function convertNumCentAr(n) {
            if (n === 0) return '';
            var hundreds = Math.floor(n / 100);
            var rest = n % 100;
            var result = '';
            var hundredWords = ['', 'مائة', 'مائتان', 'ثلاثمائة', 'أربعمائة',
                'خمسمائة', 'ستمائة', 'سبعمائة', 'ثمانمائة', 'تسعمائة'
            ];
            if (hundreds > 0) {
                result = hundredWords[hundreds];
                if (rest > 0) result += ' و';
            }
            if (rest > 0) {
                result += convertNumDizaineAr(rest);
            }
            return result;
        }

        function convertNumEntAr(n) {
            if (n === 0) return '';
            var groups = [];
            var groupNames = ['', 'ألف', 'مليون', 'مليار', 'بليون'];
            var i = 0;
            while (n > 0) {
                var group = n % 1000;
                if (group > 0) {
                    var groupWords = '';
                    var name = '';
                    if (i === 0) {
                        groupWords = convertNumCentAr(group);
                    } else {
                        if (group === 1) {
                            name = groupNames[i];
                        } else if (group === 2) {
                            name = (i === 1) ? 'ألفان' :
                                (i === 2) ? 'مليونان' :
                                (i === 3) ? 'ملياران' : 'بليونان';
                        } else {
                            groupWords = convertNumCentAr(group);
                            if (i === 1) {
                                name = (group >= 3 && group <= 10) ? 'آلاف' : 'ألف';
                            } else if (i === 2) {
                                name = (group >= 3 && group <= 10) ? 'ملايين' : 'مليون';
                            } else if (i === 3) {
                                name = (group >= 3 && group <= 10) ? 'ملايير' : 'مليار';
                            } else if (i === 4) {
                                name = (group >= 3 && group <= 10) ? 'بلايين' : 'بليون';
                            }
                        }
                        if (name !== '') {
                            groupWords = groupWords + (groupWords ? ' ' : '') + name;
                        }
                    }
                    groups.push(groupWords);
                }
                n = Math.floor(n / 1000);
                i++;
            }
            var result = groups.reverse().join(' و ');
            result = result.replace(/واحد ألف/g, 'ألف');
            result = result.replace(/اثنان ألف/g, 'ألفان');
            result = result.replace(/واحد مليون/g, 'مليون');
            result = result.replace(/اثنان مليون/g, 'مليونان');
            result = result.replace(/واحد مليار/g, 'مليار');
            result = result.replace(/اثنان مليار/g, 'ملياران');
            result = result.replace(/واحد بليون/g, 'بليون');
            result = result.replace(/اثنان بليون/g, 'بليونان');
            if (result.startsWith('و ')) result = result.substring(2);
            return result;
        }

        function convertToArabic(num) {
            if (num === 0) return 'صفر';
            if (num < 0) return 'سالب ' + convertToArabic(Math.abs(num));
            var integerPart = Math.floor(num);
            var decimalPart = Math.round((num - integerPart) * 100);
            var result = '';
            if (integerPart > 0) {
                result = convertNumEntAr(integerPart);
            } else {
                result = 'صفر';
            }
            if (decimalPart > 0) {
                var decimalWords = convertNumEntAr(decimalPart);
                if (decimalPart < 10) decimalWords = 'صفر ' + decimalWords;
                result += ' و ' + decimalWords + ' سنتيم';
            }
            return result.trim();
        }

        function convertNumDizaineFr(n) {
            if (n === 0) return '';
            var unitNames = ['', 'un', 'deux', 'trois', 'quatre', 'cinq', 'six', 'sept', 'huit', 'neuf'];
            var teenNames = ['dix', 'onze', 'douze', 'treize', 'quatorze', 'quinze', 'seize', 'dix-sept', 'dix-huit',
                'dix-neuf'
            ];
            var tensNames = ['', '', 'vingt', 'trente', 'quarante', 'cinquante', 'soixante', 'soixante-dix',
                'quatre-vingt', 'quatre-vingt-dix'
            ];
            if (n < 10) return unitNames[n];
            if (n < 20) {
                var u = n % 10;
                return teenNames[u];
            }
            var tens = Math.floor(n / 10);
            var unit = n % 10;
            if (tens === 7) {
                if (unit === 0) return 'soixante-dix';
                if (unit === 1) return 'soixante et onze';
                return 'soixante-' + unitNames[unit + 10];
            }
            if (tens === 9) {
                if (unit === 0) return 'quatre-vingt-dix';
                if (unit === 1) return 'quatre-vingt-onze';
                return 'quatre-vingt-' + unitNames[unit + 10];
            }
            if (unit === 0) return tensNames[tens];
            if (tens === 8) {
                return 'quatre-vingt-' + unitNames[unit];
            }
            if (unit === 1 && tens > 1) {
                return tensNames[tens] + ' et un';
            }
            return tensNames[tens] + '-' + unitNames[unit];
        }

        function convertNumCentFr(n) {
            if (n === 0) return '';
            var hundreds = Math.floor(n / 100);
            var remainder = n % 100;
            var result = '';
            var unitNames = ['', 'un', 'deux', 'trois', 'quatre', 'cinq', 'six', 'sept', 'huit', 'neuf'];
            if (hundreds > 0) {
                if (hundreds === 1) {
                    result = 'cent';
                } else {
                    result = unitNames[hundreds] + ' cent';
                }
                if (remainder > 0) result += ' ';
            }
            if (remainder > 0) {
                result += convertNumDizaineFr(remainder);
            }
            return result.trim();
        }

        function convertNumEntFr(n) {
            if (n === 0) return '';
            var groups = [];
            var groupNames = ['', 'mille', 'million', 'milliard', 'billion'];
            var i = 0;
            while (n > 0) {
                var group = n % 1000;
                if (group > 0) {
                    var groupWords = convertNumCentFr(group);
                    var name = '';
                    if (i > 0) {
                        if (i === 1) {
                            name = 'mille';
                        } else if (i === 2) {
                            name = (group === 1) ? 'million' : 'millions';
                        } else if (i === 3) {
                            name = (group === 1) ? 'milliard' : 'milliards';
                        } else if (i === 4) {
                            name = (group === 1) ? 'billion' : 'billions';
                        }
                    }
                    if (group === 1 && i > 1) {
                        groupWords = 'un ' + name;
                    } else if (group === 1 && i === 1) {
                        groupWords = 'mille';
                    } else if (group > 1 && i > 0) {
                        groupWords = groupWords + ' ' + name;
                    }
                    groups.push(groupWords);
                }
                n = Math.floor(n / 1000);
                i++;
            }
            var result = groups.reverse().join(' ');
            if (result.startsWith('un ')) {
                result = result.substring(3);
            }
            return result.trim();
        }

        function convertToFrench(num) {
            if (num === 0) return 'Zéro';
            if (num < 0) return 'Moins ' + convertToFrench(Math.abs(num));
            var integerPart = Math.floor(num);
            var decimalPart = Math.round((num - integerPart) * 100);
            var result = '';
            if (integerPart > 0) {
                result = convertNumEntFr(integerPart);
            } else {
                result = 'Zéro';
            }
            if (decimalPart > 0) {
                var decimalWords = convertNumEntFr(decimalPart);
                if (decimalPart === 1) {
                    result += ' et ' + decimalWords + ' centime';
                } else {
                    result += ' et ' + decimalWords + ' centimes';
                }
            }
            result = result.charAt(0).toUpperCase() + result.slice(1);
            return result.trim();
        }

        function convertNumDizaineEn(n) {
            if (n === 0) return '';
            var unitNames = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
            var teenNames = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen',
                'Eighteen', 'Nineteen'
            ];
            var tensNames = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
            if (n < 10) return unitNames[n];
            if (n < 20) {
                var u = n % 10;
                return teenNames[u];
            }
            var tens = Math.floor(n / 10);
            var unit = n % 10;
            if (unit === 0) return tensNames[tens];
            return tensNames[tens] + '-' + unitNames[unit];
        }

        function convertNumCentEn(n) {
            if (n === 0) return '';
            var hundreds = Math.floor(n / 100);
            var remainder = n % 100;
            var result = '';
            var unitNames = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
            if (hundreds > 0) {
                result = unitNames[hundreds] + ' Hundred';
                if (remainder > 0) result += ' ';
            }
            if (remainder > 0) {
                result += convertNumDizaineEn(remainder);
            }
            return result.trim();
        }

        function convertNumEntEn(n) {
            if (n === 0) return '';
            var groups = [];
            var groupNames = ['', 'thousand', 'million', 'billion', 'trillion'];
            var i = 0;
            while (n > 0) {
                var group = n % 1000;
                if (group > 0) {
                    var groupWords = convertNumCentEn(group);
                    var name = '';
                    if (i > 0) {
                        if (group === 1) {
                            name = groupNames[i];
                        } else {
                            name = groupNames[i] + 's';
                        }
                    }
                    if (name !== '') {
                        groupWords = groupWords + ' ' + name;
                    }
                    groups.push(groupWords);
                }
                n = Math.floor(n / 1000);
                i++;
            }
            return groups.reverse().join(' ');
        }

        function convertToEnglish(num) {
            if (num === 0) return 'Zero';
            if (num < 0) return 'Minus ' + convertToEnglish(Math.abs(num));
            var integerPart = Math.floor(num);
            var decimalPart = Math.round((num - integerPart) * 100);
            var result = '';
            if (integerPart > 0) {
                result = convertNumEntEn(integerPart);
            } else {
                result = 'Zero';
            }
            if (decimalPart > 0) {
                var decimalWords = convertNumEntEn(decimalPart);
                if (decimalPart === 1) {
                    result += ' and ' + decimalWords + ' cent';
                } else {
                    result += ' and ' + decimalWords + ' cents';
                }
            }
            result = result.charAt(0).toUpperCase() + result.slice(1);
            return result.trim();
        }

        // ================================================================
        // دوال مساعدة
        // ================================================================

        function formatNumberWithCommas(num) {
            if (num === undefined || num === null) return '';
            if (typeof num === 'string') {
                if (num.trim() === '') return '';
                const parsed = parseNumberFromInput(num);
                if (isNaN(parsed)) return num;
                num = parsed;
            }
            if (typeof num !== 'number' || isNaN(num)) return '';
            const rounded = Math.round(num * 100) / 100;
            let parts = rounded.toFixed(2).split('.');
            parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
            return parts.join(',');
        }

        function parseNumberFromInput(str) {
            if (!str || str.trim() === '') return 0;
            let cleaned = str.trim();
            cleaned = cleaned.replace(/\s/g, '');
            if (cleaned.includes(',') && cleaned.includes('.')) {
                const lastComma = cleaned.lastIndexOf(',');
                const lastDot = cleaned.lastIndexOf('.');
                if (lastComma > lastDot) {
                    let parts = cleaned.split(',');
                    let intPart = parts[0].replace(/\./g, '');
                    let decPart = parts[1] || '';
                    cleaned = intPart + '.' + decPart;
                } else {
                    let parts = cleaned.split('.');
                    let intPart = parts[0].replace(/,/g, '');
                    let decPart = parts[1] || '';
                    cleaned = intPart + '.' + decPart;
                }
            } else if (cleaned.includes(',')) {
                cleaned = cleaned.replace(/,/g, '.');
            }
            if (cleaned.includes('.')) {
                let parts = cleaned.split('.');
                parts[0] = parts[0].replace(/[.,]/g, '');
                cleaned = parts[0] + '.' + parts[1];
            } else {
                cleaned = cleaned.replace(/[.,]/g, '');
            }
            const result = parseFloat(cleaned);
            return isNaN(result) ? 0 : result;
        }

        function getCurrencyNames(currency, lang) {
            const isArabic = lang === 'ar';
            const isFrench = lang === 'fr';
            const isEnglish = lang === 'en';
            let mainName, subName;
            if (currency === 'DZD') {
                if (isArabic) { mainName = 'دينار جزائري';
                    subName = 'سنتيم'; } else if (isFrench) { mainName = 'dinar algérien';
                    subName = 'centime'; } else { mainName = 'Algerian dinar';
                    subName = 'centime'; }
            } else if (currency === 'EUR') {
                if (isArabic) { mainName = 'يورو';
                    subName = 'سنت'; } else if (isFrench) { mainName = 'euro';
                    subName = 'centime'; } else { mainName = 'euro';
                    subName = 'cent'; }
            } else {
                if (isArabic) { mainName = 'دولار';
                    subName = 'سنت'; } else if (isFrench) { mainName = 'dollar';
                    subName = 'cent'; } else { mainName = 'dollar';
                    subName = 'cent'; }
            }
            return { mainName, subName };
        }

        function getConverter(lang) {
            if (lang === 'ar') return convertToArabic;
            if (lang === 'fr') return convertToFrench;
            if (lang === 'en') return convertToEnglish;
            return convertToArabic;
        }

        function updateAmountWordsForField(wordsEl, amountValue, lang, currency) {
            const num = parseNumberFromInput(amountValue);
            const contentSpan = wordsEl.querySelector('.field-content');
            if (!contentSpan) return;
            let text = '';
            const integerPart = Math.floor(num);
            const decimalPart = Math.round((num - integerPart) * 100);
            const converter = getConverter(lang);
            const { mainName, subName } = getCurrencyNames(currency, lang);

            if (lang === 'ar') {
                let integerWords = converter(integerPart);
                if (integerPart === 0) integerWords = 'صفر';
                text = integerWords + ' ' + mainName;
                if (decimalPart > 0) {
                    let decimalWords = converter(decimalPart);
                    if (decimalPart < 10) decimalWords = 'صفر ' + decimalWords;
                    text += ' و ' + decimalWords + ' ' + subName;
                }
            } else if (lang === 'fr') {
                let integerWords = converter(integerPart);
                if (integerPart === 0) integerWords = 'Zéro';
                text = integerWords + ' ' + mainName;
                if (decimalPart > 0) {
                    let decimalWords = converter(decimalPart);
                    if (decimalPart < 10) decimalWords = 'zéro ' + decimalWords;
                    text += ' et ' + decimalWords + ' ' + subName;
                }
            } else {
                let integerWords = converter(integerPart);
                if (integerPart === 0) integerWords = 'Zero';
                text = integerWords + ' ' + mainName;
                if (decimalPart > 0) {
                    let decimalWords = converter(decimalPart);
                    if (decimalPart < 10) decimalWords = 'zero ' + decimalWords;
                    text += ' and ' + decimalWords + ' ' + subName;
                }
            }

            let span = contentSpan.querySelector('span:not(.field-label)');
            if (!span) span = contentSpan;
            span.textContent = text;
            wordsEl.dataset.value = text;
        }

        function updateAllAmountWords() {
            const defaultLang = 'ar';
            const defaultCurrency = 'DZD';
            document.querySelectorAll('.draggable-field[data-field-type="amount"]').forEach(amountEl => {
                const hiddenInput = amountEl.querySelector('.field-content input[type="hidden"]');
                if (!hiddenInput) return;
                const value = hiddenInput.value;
                const linkedIds = amountEl.dataset.linkedWordsIds ? amountEl.dataset.linkedWordsIds.split(',') : [];
                linkedIds.forEach(lid => {
                    if (fields[lid]) {
                        const wEl = fields[lid];
                        const wLang = wEl.dataset.lang || defaultLang;
                        const wCurrency = wEl.dataset.currency || defaultCurrency;
                        updateAmountWordsForField(wEl, value, wLang, wCurrency);
                    }
                });
            });
        }

        // ================================================================
        // الحالة العامة
        // ================================================================

        let fields = {};
        let selectedIds = new Set();
        let selectedId = null;
        let dragData = null;
        let resizeData = null;
        let snapEnabled = false;
        let gridVisible = false;
        let alignGuidesEnabled = true;
        let fieldCounter = 0;
        let zoomLevel = 1;
        let panX = 0,
            panY = 0;
        let isPanning = false;
        let panStartX = 0,
            panStartY = 0;
        let panStartPX = 0,
            panStartPY = 0;
        let designMode = true;
        let rulerVisible = true;
        let currentTheme = 'dark';
        let currentProjectPath = null;
        let currentProjectName = 'مشروع جديد';
        let projectData = null;
        let guideColor = '#f39c12';
        let animationFrameId = null;

        const paperSizes = {
            'A4': { w: 210, h: 297 },
            'Letter': { w: 216, h: 279 },
            'Custom': { w: 210, h: 297 }
        };

        function generateId(type) {
            fieldCounter++;
            const prefixMap = {
                'text': 'txt',
                'amount': 'amt',
                'amount_words': 'wrd',
                'checkbox': 'chk',
                'radio': 'rad',
                'select': 'sel',
                'date': 'dat',
                'image': 'img'
            };
            const prefix = prefixMap[type] || 'fld';
            return prefix + '_' + fieldCounter;
        }

        function formatDateDisplay(value, format) {
            if (!value) return '';
            try {
                const parts = value.split('-');
                if (parts.length !== 3) return value;
                const year = parts[0];
                const month = parts[1];
                const day = parts[2];
                if (format === 'dd/mm/yyyy') return day + '/' + month + '/' + year;
                if (format === 'mm/dd/yyyy') return month + '/' + day + '/' + year;
                if (format === 'yyyy/mm/dd') return year + '/' + month + '/' + day;
                return value;
            } catch (e) { return value; }
        }

        function parseDateInput(str) {
            if (!str) return '';
            let parts;
            if (str.includes('-')) {
                parts = str.split('-');
                if (parts.length === 3) return parts[0] + '-' + parts[1] + '-' + parts[2];
                return str;
            }
            if (str.includes('/')) {
                parts = str.split('/');
                if (parts.length !== 3) return str;
                if (parts[0].length === 4) {
                    return parts[0] + '-' + parts[1] + '-' + parts[2];
                } else if (parts[2].length === 4) {
                    return parts[2] + '-' + parts[1] + '-' + parts[0];
                } else {
                    return parts[2] + '-' + parts[1] + '-' + parts[0];
                }
            }
            return str;
        }

        function hexToRgba(hex, alpha) {
            const r = parseInt(hex.slice(1, 3), 16);
            const g = parseInt(hex.slice(3, 5), 16);
            const b = parseInt(hex.slice(5, 7), 16);
            return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
        }

        function rgbToHex(rgb) {
            if (!rgb || rgb === '') return '#000000';
            if (rgb.startsWith('#')) return rgb;
            const match = rgb.match(/(\d+)/g);
            if (!match) return '#000000';
            const r = parseInt(match[0]);
            const g = parseInt(match[1]);
            const b = parseInt(match[2]);
            return '#' + [r, g, b].map(c => c.toString(16).padStart(2, '0')).join('');
        }

        function snapValue(value, gridSize) {
            if (!snapEnabled) return value;
            return Math.round(value / gridSize) * gridSize;
