        // ================================================================

        function applyLabelPosition(container, inputEl, labelEl, position, textAlign) {
            if (!container || !inputEl || !labelEl) return;
            container.style.flexDirection = 'row';
            container.style.alignItems = 'center';
            container.style.justifyContent = 'center';
            container.style.flexWrap = 'nowrap';
            inputEl.style.order = 0;
            labelEl.style.order = 0;
            inputEl.style.margin = '0';
            labelEl.style.margin = '0';
            const parent = container.closest('.draggable-field');
            const showLabel = parent && parent.dataset.showLabel === 'true';
            labelEl.style.display = showLabel ? '' : 'none';
            if (textAlign) {
                labelEl.style.textAlign = textAlign;
            } else {
                labelEl.style.textAlign = 'inherit';
            }
            switch (position) {
                case 'right':
                    container.style.flexDirection = 'row';
                    inputEl.style.order = 0;
                    labelEl.style.order = 1;
                    break;
                case 'left':
                    container.style.flexDirection = 'row';
                    inputEl.style.order = 1;
                    labelEl.style.order = 0;
                    break;
                case 'top':
                    container.style.flexDirection = 'column';
                    container.style.alignItems = 'center';
                    inputEl.style.order = 0;
                    labelEl.style.order = 1;
                    break;
                case 'bottom':
                    container.style.flexDirection = 'column';
                    container.style.alignItems = 'center';
                    inputEl.style.order = 1;
                    labelEl.style.order = 0;
                    break;
                default:
                    container.style.flexDirection = 'row';
                    inputEl.style.order = 0;
                    labelEl.style.order = 1;
            }
            if (position === 'top' || position === 'bottom') {
                inputEl.style.width = 'auto';
                labelEl.style.width = '100%';
                if (!textAlign) labelEl.style.textAlign = 'center';
            } else {
                inputEl.style.width = 'auto';
                labelEl.style.width = 'auto';
            }
        }

