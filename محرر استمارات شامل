        async function saveProject() {
            if (!currentProjectPath && !('showDirectoryPicker' in window)) {
                const data = collectFieldsData();
                localStorage.setItem('sfp01_fields', JSON.stringify(data));
                alert('✅ تم حفظ المشروع محلياً: ' + (currentProjectName || 'مشروع محلي'));
                return;
            }

            if (!currentProjectPath) {
                alert('⚠️ يرجى فتح أو إنشاء مشروع أولاً');
                return;
            }

            try {
                const data = collectFieldsData();
                const json = JSON.stringify(data, null, 2);
                const dataFile = await currentProjectPath.getFileHandle('fields.json', { create: true });
                const writable = await dataFile.createWritable();
                await writable.write(json);
                await writable.close();

                const img = document.getElementById('formImage');
                if (img.src && img.src.startsWith('data:image')) {
                    try {
                        const response = await fetch(img.src);
                        const blob = await response.blob();
                        const imgFile = await currentProjectPath.getFileHandle('background.jpg', { create: true });
                        const w = await imgFile.createWritable();
                        await w.write(blob);
                        await w.close();
                    } catch (e) { /* ignore */ }
                }

                alert('✅ تم حفظ المشروع: ' + currentProjectName);
            } catch (e) {
                alert('❌ خطأ في الحفظ: ' + e.message);
            }
        }

