                const downloadAll = confirm('تصدير المشروع مع الصورة؟');

                if (downloadAll) {
                    const img = document.getElementById('formImage');
                    let imgData = null;
                    if (img.src && img.src.startsWith('data:image')) {
                        imgData = img.src;
                    } else if (img.src) {
