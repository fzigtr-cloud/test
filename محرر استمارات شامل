        function alignFields(type) {
            const selected = getSelectedElements();
            if (selected.length < 2) { alert('⚠️ اختر حقلين على الأقل'); return; }
            const ref = selected[0];
            selected.forEach(el => {
                if (el === ref) return;
                let newLeft = parseFloat(el.style.left);
                let newTop = parseFloat(el.style.top);
                switch (type) {
                    case 'left':
                        newLeft = parseFloat(ref.style.left);
                        break;
                    case 'center':
                        newLeft = parseFloat(ref.style.left) + (parseFloat(ref.style.width) - parseFloat(el.style
                        .width)) / 2;
                        break;
                    case 'right':
                        newLeft = parseFloat(ref.style.left) + parseFloat(ref.style.width) - parseFloat(el.style
                        .width);
                        break;
                    case 'top':
                        newTop = parseFloat(ref.style.top);
                        break;
                    case 'middle':
                        newTop = parseFloat(ref.style.top) + (parseFloat(ref.style.height) - parseFloat(el.style
                        .height)) / 2;
                        break;
                    case 'bottom':
                        newTop = parseFloat(ref.style.top) + parseFloat(ref.style.height) - parseFloat(el.style
                        .height);
                        break;
                }
                el.style.left = Math.max(0, Math.min(100 - parseFloat(el.style.width), newLeft)) + '%';
                el.style.top = Math.max(0, Math.min(100 - parseFloat(el.style.height), newTop)) + '%';
            });
            savePositionsSilent();
            if (selectedIds.size === 1) {
                const firstId = getSelectedIds()[0];
                updatePropertiesPanel(firstId);
            }
        }

        function distributeFields(type) {
            const selected = getSelectedElements();
            if (selected.length < 3) { alert('⚠️ اختر 3 حقول على الأقل'); return; }
            const sorted = Array.from(selected).sort((a, b) => {
                const aPos = type === 'horiz' ? parseFloat(a.style.left) : parseFloat(a.style.top);
                const bPos = type === 'horiz' ? parseFloat(b.style.left) : parseFloat(b.style.top);
                return aPos - bPos;
            });
            const first = sorted[0];
            const last = sorted[sorted.length - 1];
            const start = type === 'horiz' ? parseFloat(first.style.left) : parseFloat(first.style.top);
            const end = type === 'horiz' ? parseFloat(last.style.left) + parseFloat(last.style.width) : parseFloat(last
                .style.top) + parseFloat(last.style.height);
            const step = (end - start) / (sorted.length - 1);
            sorted.forEach((el, idx) => {
                const pos = start + idx * step;
                if (type === 'horiz') {
                    el.style.left = Math.max(0, Math.min(100 - parseFloat(el.style.width), pos)) + '%';
                } else {
                    el.style.top = Math.max(0, Math.min(100 - parseFloat(el.style.height), pos)) + '%';
                }
            });
            savePositionsSilent();
            if (selectedIds.size === 1) {
                const firstId = getSelectedIds()[0];
                updatePropertiesPanel(firstId);
            }
        }

